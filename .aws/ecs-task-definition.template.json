{
  "family": "mugen-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "{{ECS_TASK_EXECUTION_ROLE_ARN}}",
  "taskRoleArn": "{{ECS_TASK_ROLE_ARN}}",
  "containerDefinitions": [
    {
      "name": "mugen-api",
      "image": "{{IMAGE_URI}}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "MUGEN_CONFIG_FILE",
          "value": "conf/mugen.toml.sample"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "APP_NAME",
          "value": "mugen-api"
        },
        {
          "name": "PORT",
          "value": "8000"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "CORS_ALLOWED_ORIGINS",
          "value": "{{CORS_ALLOWED_ORIGINS}}"
        },
        {
          "name": "MUGEN_PLATFORMS",
          "value": "web"
        },
        {
          "name": "MUGEN_PHASE_B_CRITICAL_PLATFORMS",
          "value": "web"
        },
        {
          "name": "MUGEN_ENABLED_EXTENSIONS",
          "value": "core.fw.channel_orchestration,core.fw.audit"
        },
        {
          "name": "MUGEN_EXTENSIONS_JSON",
          "value": ""
        },
        {
          "name": "MUGEN_MIGRATION_TRACKS_JSON",
          "value": ""
        },
        {
          "name": "ACP_SEED_ACP",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "{{DATABASE_URL_SECRET_ARN}}"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "{{SECRET_KEY_SECRET_ARN}}"
        },
        {
          "name": "ACP_ADMIN_USERNAME",
          "valueFrom": "{{ACP_ADMIN_USERNAME_SECRET_ARN}}"
        },
        {
          "name": "ACP_ADMIN_LOGIN_EMAIL",
          "valueFrom": "{{ACP_ADMIN_LOGIN_EMAIL_SECRET_ARN}}"
        },
        {
          "name": "ACP_ADMIN_PASSWORD",
          "valueFrom": "{{ACP_ADMIN_PASSWORD_SECRET_ARN}}"
        },
        {
          "name": "ACP_ADMIN_PASSWORD_HASH",
          "valueFrom": "{{ACP_ADMIN_PASSWORD_HASH_SECRET_ARN}}"
        },
        {
          "name": "ACP_SECRET_KEY",
          "valueFrom": "{{ACP_SECRET_KEY_SECRET_ARN}}"
        },
        {
          "name": "ACP_MANAGED_SECRET_ENCRYPTION_KEY",
          "valueFrom": "{{ACP_MANAGED_SECRET_ENCRYPTION_KEY_SECRET_ARN}}"
        },
        {
          "name": "ACP_REFRESH_TOKEN_PEPPER",
          "valueFrom": "{{ACP_REFRESH_TOKEN_PEPPER_SECRET_ARN}}"
        },
        {
          "name": "ACP_JWT_CONFIG_JSON",
          "valueFrom": "{{ACP_JWT_CONFIG_JSON_SECRET_ARN}}"
        },
        {
          "name": "MUGEN_CONFIG_OVERLAY_JSON",
          "valueFrom": "{{MUGEN_CONFIG_OVERLAY_JSON_SECRET_ARN}}"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "{{ECS_LOG_GROUP}}",
          "awslogs-region": "{{AWS_REGION}}",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
