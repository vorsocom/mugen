            "risk_priority_high"
          ],
          "Obligations": [
            {
              "Type": "require_approval",
              "Required": true
            }
          ]
        },
        {
          "Name": "default_allow",
          "Effect": "allow",
          "Reasons": [
            "default_allow"
          ],
          "Obligations": [
            {
              "Type": "log_reason",
              "Required": false
            }
          ]
        }
      ],
      "Default": {
        "Decision": "deny",
        "Reasons": [
          "default_deny"
        ]
      }
    }
  },
  "lookup": {
    "field": "Code",
    "value": "__POLICY_CODE__"
  },
  "status_field": "Code",
  "actions": [
    {
