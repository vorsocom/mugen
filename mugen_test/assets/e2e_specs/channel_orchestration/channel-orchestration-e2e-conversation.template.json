{
  "runtime": {
    "spawn_hypercorn": true,
    "hypercorn_cmd": "__HYPERCORN_CMD__",
    "health_url": "http://127.0.0.1:8081/api/core/acp/v1/auth/.well-known/jwks.json",
    "startup_timeout_secs": 30
  },
  "base_url": "http://127.0.0.1:8081/api/core/acp/v1",
  "credentials": {
    "username": "admin",
    "password": "aDmin,123"
  },
  "tenant_id": null,
  "entity_set": "ConversationStates",
  "create_payload": {
    "SenderKey": "__SENDER_KEY__"
  },
  "lookup": {
    "field": "SenderKey",
    "value": "__SENDER_KEY__"
  },
  "status_field": "Status",
  "actions": [
    {
      "name": "set_fallback",
      "target": "entity",
      "expect_code": 200,
      "payload": {
        "RowVersion": "__ROW_VERSION__",
        "FallbackMode": "default_route",
        "FallbackTarget": "queue.fallback.e2e",
        "Reason": "e2e fallback setup"
      }
    },
    {
      "name": "evaluate_intake",
      "target": "entity",
      "expect_code": 200,
      "payload": {
        "RowVersion": "__ROW_VERSION__",
        "Keyword": "billing"
      }
    },
    {
      "name": "route",
      "target": "entity",
      "expect_code": 200,
      "payload": {
        "RowVersion": "__ROW_VERSION__"
      }
    },
    {
      "name": "escalate",
      "target": "entity",
      "expect_code": 200,
      "payload": {
        "RowVersion": "__ROW_VERSION__",
        "Reason": "e2e escalation"
      }
    },
    {
      "name": "apply_throttle",
      "target": "entity",
      "expect_code": 200,
      "payload": {
        "RowVersion": "__ROW_VERSION__",
        "IncrementCount": 1
      }
    }
  ],
  "assertions": {
    "final_status": "escalated",
    "event_entity_set": "OrchestrationEvents",
    "event_entity_id_field": "ConversationStateId",
    "event_type_field": "EventType",
    "expected_event_sequence": [
      "set_fallback",
      "evaluate_intake",
      "route",
      "escalate",
      "apply_throttle"
    ]
  },
  "negative_creates": [
    {
      "name": "missing_sender_key",
      "entity_set": "ConversationStates",
      "expect_code": 400,
      "payload": {}
    }
  ],
  "positive_creates": []
}
