# Local container defaults. Do not use these values in production.
MUGEN_CONFIG_FILE=conf/mugen.toml.sample
MUGEN_CONFIG_OVERLAY_FILE=conf/mugen.overlay.example.json
MUGEN_CONFIG_OVERLAY_JSON=
ENVIRONMENT=development
APP_NAME=mugen-api
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
MUGEN_PLATFORMS=web
MUGEN_PHASE_B_CRITICAL_PLATFORMS=web
MUGEN_ENABLED_EXTENSIONS=core.fw.channel_orchestration
MUGEN_EXTENSIONS_JSON=
MUGEN_MIGRATION_TRACKS_JSON=

# For `docker run`, use host.docker.internal when PostgreSQL runs on the host.
# Docker Compose overrides this to use the bundled postgres service.
DATABASE_URL=postgresql+psycopg://mugen:mugen@host.docker.internal:5432/mugen
SECRET_KEY=local-dev-quart-secret-key-0123456789abcdef
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local HTTPS testing. Keep these blank for plain HTTP.
# For https://localdev.vorsocomputing.com:8443, put cert/key files in
# TLS_CERT_DIR and point TLS_CERT_FILE/TLS_KEY_FILE at their container paths.
TLS_CERT_DIR=./_dev/tls
TLS_CERT_FILE=
TLS_KEY_FILE=

# Local-only ACP bootstrap admin values. Replace for any shared environment.
ACP_SEED_ACP=true
ACP_ADMIN_USERNAME=admin
ACP_ADMIN_LOGIN_EMAIL=admin@example.com
ACP_ADMIN_PASSWORD=LocalAdmin1!
# Leave blank for Docker Compose local smoke; the config overlay generates a
# local-only hash from ACP_ADMIN_PASSWORD. For docker run or production, supply
# a Werkzeug generate_password_hash value through a secret-aware channel.
ACP_ADMIN_PASSWORD_HASH=

# Local-only ACP/JWT values. If ACP_JWT_CONFIG_JSON is blank in development, the
# config overlay generates an ephemeral local key from ACP_JWT_ACTIVE_KID. For
# production/ECS, inject ACP_JWT_CONFIG_JSON as a single Secrets Manager value
# containing active_kid, issuer, audience, and keys.
ACP_SECRET_KEY=local-dev-acp-secret-key-0123456789abcdef
ACP_MANAGED_SECRET_ENCRYPTION_KEY=local-dev-acp-managed-secret-key-0123456789abcdef
ACP_REFRESH_TOKEN_PEPPER=local-dev-refresh-token-pepper-0123456789abcdef
ACP_JWT_ACTIVE_KID=local-dev-ed25519
ACP_JWT_ISSUER=mugen-local
ACP_JWT_AUDIENCE=mugen-local
ACP_JWT_CONFIG_JSON=
