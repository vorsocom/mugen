bind = "0.0.0.0:443"
certfile = "/etc/letsencrypt/live/{domain}/fullchain.pem"
keyfile = "/etc/letsencrypt/live/{domain}/privkey.pem"
# Optional plaintext listener for redirects or ACME challenges.
insecure-bind = "0.0.0.0:80"
# Replace {domain} with the public hostname served by this instance.
server_names = "{domain}"

accesslog = "/var/log/com.vorsocomputing.mugen.hypercorn.access.log"
errorlog = "/var/log/com.vorsocomputing.mugen.hypercorn.error.log"
