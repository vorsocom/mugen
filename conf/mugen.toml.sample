contrib = "mugen.core.plugin.ops_case.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_sla.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_sla"
