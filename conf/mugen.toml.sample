[mugen]
assistant.persona = ""
beta.active = true
beta.message = ""
debug_conversation = false
environment = "development"
logger.level = 10
logger.name = "COM.VORSOCOMPUTING.MUGEN"
platforms = [
  "web",
  # "matrix",
  # "whatsapp",
]
storage.keyval.relational.namespace_default = "core"
storage.keyval.relational.list_limit_default = 200
runtime.phase_b.readiness_grace_seconds = 0.0
runtime.phase_b.startup_timeout_seconds = 30.0
runtime.phase_b.critical_platforms = ["web"]
runtime.phase_b.degrade_on_critical_exit = true
runtime.profile = "platform_full"   # api_only|web_only|platform_full

[mugen.commands]
clear = "..."

[mugen.messaging]
# Max number of chat history messages persisted and forwarded to completion context.
history_max_messages = 40
# Max CAS retries for chat-history persistence across workers/processes.
history_save_cas_retries = 5
# Timeout in seconds for extension callbacks (CP/CTX/RAG/RPP/CT).
extension_timeout_seconds = 10.0
# If true, CT extensions with non-empty triggers only run on trigger matches.
ct_trigger_prefilter_enabled = true

# === IPC (core dispatcher policy) ===
[ipc.dispatch]
timeout_seconds = 10.0
max_timeout_seconds = 30.0

[mugen.modules.core]
client.matrix = "mugen.core.client.matrix:DefaultMatrixClient"
client.whatsapp = "mugen.core.client.whatsapp:DefaultWhatsAppClient"
client.web = "mugen.core.client.web:DefaultWebClient"

gateway.completion = "mugen.core.gateway.completion.bedrock:BedrockCompletionGateway"
# gateway.email = "mugen.core.gateway.email.smtp:SMTPEmailGateway"
# gateway.email = "mugen.core.gateway.email.ses:SESEmailGateway"
# gateway.knowledge = "mugen.core.gateway.knowledge.qdrant:QdrantKnowledgeGateway"
gateway.logging = "mugen.core.gateway.logging.standard:StandardLoggingGateway"
gateway.storage.keyval = "mugen.core.gateway.storage.keyval.relational:RelationalKeyValStorageGateway"
gateway.storage.relational = "mugen.core.gateway.storage.rdbms.sqla.sqla_gateway:SQLAlchemyRelationalStorageGateway"
gateway.storage.web_runtime = "mugen.core.gateway.storage.web_runtime.relational_store:RelationalWebRuntimeStore"

service.ipc = "mugen.core.service.ipc:DefaultIPCService"
service.messaging = "mugen.core.service.messaging:DefaultMessagingService"
service.nlp = "mugen.core.service.nlp:DefaultNLPService"
service.platform = "mugen.core.service.platform:DefaultPlatformService"
service.user = "mugen.core.service.user:DefaultUserService"

# Core framework plugins.
[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.acp.fw_ext:AdminFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.acp"
namespace = "com.vorsocomputing.mugen.acp"
models = "mugen.core.plugin.acp.model"
contrib = "mugen.core.plugin.acp.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.audit.fw_ext:AuditFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.audit"
namespace = "com.vorsocomputing.mugen.audit"
models = "mugen.core.plugin.audit.model"
contrib = "mugen.core.plugin.audit.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_vpn.fw_ext:OpsVpnFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_vpn"
namespace = "com.vorsocomputing.mugen.ops_vpn"
models = "mugen.core.plugin.ops_vpn.model"
contrib = "mugen.core.plugin.ops_vpn.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_case.fw_ext:OpsCaseFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_case"
namespace = "com.vorsocomputing.mugen.ops_case"
models = "mugen.core.plugin.ops_case.model"
contrib = "mugen.core.plugin.ops_case.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_sla.fw_ext:OpsSlaFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_sla"
namespace = "com.vorsocomputing.mugen.ops_sla"
models = "mugen.core.plugin.ops_sla.model"
contrib = "mugen.core.plugin.ops_sla.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_metering.fw_ext:OpsMeteringFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_metering"
namespace = "com.vorsocomputing.mugen.ops_metering"
models = "mugen.core.plugin.ops_metering.model"
contrib = "mugen.core.plugin.ops_metering.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_workflow.fw_ext:OpsWorkflowFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_workflow"
namespace = "com.vorsocomputing.mugen.ops_workflow"
models = "mugen.core.plugin.ops_workflow.model"
contrib = "mugen.core.plugin.ops_workflow.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_governance.fw_ext:OpsGovernanceFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_governance"
namespace = "com.vorsocomputing.mugen.ops_governance"
models = "mugen.core.plugin.ops_governance.model"
contrib = "mugen.core.plugin.ops_governance.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_reporting.fw_ext:OpsReportingFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_reporting"
namespace = "com.vorsocomputing.mugen.ops_reporting"
models = "mugen.core.plugin.ops_reporting.model"
contrib = "mugen.core.plugin.ops_reporting.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_connector.fw_ext:OpsConnectorFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.ops_connector"
namespace = "com.vorsocomputing.mugen.ops_connector"
models = "mugen.core.plugin.ops_connector.model"
contrib = "mugen.core.plugin.ops_connector.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.billing.fw_ext:BillingFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.billing"
namespace = "com.vorsocomputing.mugen.billing"
models = "mugen.core.plugin.billing.model"
contrib = "mugen.core.plugin.billing.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.knowledge_pack.fw_ext:KnowledgePackFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.knowledge_pack"
namespace = "com.vorsocomputing.mugen.knowledge_pack"
models = "mugen.core.plugin.knowledge_pack.model"
contrib = "mugen.core.plugin.knowledge_pack.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.channel_orchestration.fw_ext:ChannelOrchestrationFWExtension"
enabled = true
name = "com.vorsocomputing.mugen.channel_orchestration"
namespace = "com.vorsocomputing.mugen.channel_orchestration"
models = "mugen.core.plugin.channel_orchestration.model"
contrib = "mugen.core.plugin.channel_orchestration.contrib"

# Optional WhatsApp WACAPI framework plugin.
[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.whatsapp.wacapi.fw_ext:WACAPIFWExtension"
enabled = false
name = "com.vorsocomputing.mugen.whatsapp.wacapi"
namespace = "com.vorsocomputing.mugen.whatsapp.wacapi"
models = "mugen.core.plugin.whatsapp.wacapi.model"
contrib = "mugen.core.plugin.whatsapp.wacapi.contrib"

# Optional Web REST/SSE framework plugin.
[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.web.fw_ext:WebFWExtension"
enabled = false
name = "com.vorsocomputing.mugen.web"
namespace = "com.vorsocomputing.mugen.web"
models = "mugen.core.plugin.web.model"
contrib = "mugen.core.plugin.web.contrib"

# Context.
[[mugen.modules.core.plugins]]
type = "ctx"
path = "mugen.core.plugin.context.persona.ctx_ext:SystemPersonaCTXExtension"

# Commands.
[[mugen.modules.core.plugins]]
type = "cp"
path = "mugen.core.plugin.command.clear_history.cp_ext:ClearChatHistoryICPExtension"

# Message handler.
[[mugen.modules.core.plugins]]
type = "mh"
path = "mugen.core.plugin.message_handler.text.mh_ext:DefaultTextMHExtension"

# Optional WACAPI IPC extension.
# [[mugen.modules.core.plugins]]
# type = "ipc"
# path = "mugen.core.plugin.whatsapp.wacapi.ipc_ext:WACAPIIPCExtension"

# Downstream extensions.
# [[mugen.modules.extensions]]
# type = "cp"
# path = "your_module:YourExtensionClass"

# === ACP plugin ===
[acp]
plugin_name = "com.vorsocomputing.mugen.acp"
namespace = "com.vorsocomputing.mugen.acp"

admin_login_email = "admin@example.com"
test_email_recipient = "<set-test-email-recipient>"
admin_password = "<set-admin-password>"
admin_password_hash = ""
admin_username = "admin"

cors_origins = ["*"]
enforce_password_policy = true

login_access_expiry = 300   # 5 minutes
login_dummy_hash = ""
login_refresh_expiry = 604800   # 7 days
tenant_invitation_ttl_seconds = 604800   # 7 days
tenant_invitation_invite_base_url = "https://example.com/invite"

password_policy = "^(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[!@#\\$&*~,]).{8,}$"
refresh_token_pepper = "<set-refresh-token-pepper>"

rgql_allow_expand_wildcard = true
rgql_default_top = 100
rgql_max_expand_depth = 4
rgql_max_expand_paths = 10
rgql_max_filter_nav_depth = 4
rgql_max_filter_terms = 25
rgql_max_orderby = 5
rgql_max_select = 50
rgql_max_skip = 10_000
rgql_max_top = 500

secret_key = "<set-acp-secret-key>"
seed_acp = true

[acp.ipc]
timeout_seconds = 10.0
max_timeout_seconds = 30.0
# Explicit allow-list entries in "<platform>:<command>" format.
allowed_commands = ["whatsapp:whatsapp_wacapi_event", "matrix:matrix_event"]

[acp.argon2]
time_cost = 2
memory_cost = 65536   # 64 * 1024
parallelism = 2
hash_len = 32

[acp.jwt]
active_kid = "<kid>"
audience = "<audience>"
issuer = "<issuer>"

[[acp.jwt.keys]]
kid = "<kid>"
alg = "EdDSA"
pem = "-----BEGIN PRIVATE KEY-----\\n<replace-with-private-key>\\n-----END PRIVATE KEY-----\\n"

[acp.key_management.providers.local.keys.ops_connector_secret]
ops_connector_default = "dev-ops-connector-secret"

# === OPS CONNECTOR ===
[ops_connector]
timeout_seconds_default = 10.0
max_retries_default = 2
retry_backoff_seconds_default = 0.5
retry_status_codes_default = [429, 500, 502, 503, 504]
secret_purpose = "ops_connector_secret"
redacted_keys = ["password", "token", "secret", "authorization", "api_key"]

# === AWS Bedrock ===
[aws.bedrock]
api.access_key_id = "<aws-access-key-id>"
# Set model IDs per operation.
# In auto mode, the Bedrock gateway tries Converse first and falls back to
# InvokeModel when Converse is unsupported for the selected model.
# Built-in InvokeModel serializers currently cover:
# anthropic.*, meta.*, amazon.titan-text*, amazon.nova*, ai21.j2*,
# ai21.jamba*, cohere.*, mistral.*, deepseek.*, openai.*, writer.*
api.classification.model = ""
api.classification.max_tokens = 1024
api.classification.temp = 0.0
api.classification.top_p = 0.9
api.completion.model = ""
api.completion.max_tokens = 1024
api.completion.temp = 0.0
api.completion.top_p = 0.9
api.region = ""
api.secret_access_key = "<aws-secret-access-key>"
api.connect_timeout_seconds = 10.0
api.read_timeout_seconds = 30.0
api.max_attempts = 3

# === AWS SES (optional outbound email gateway) ===
[aws.ses]
api.region = "us-east-1"
# Optional: leave blank to use environment/instance profile credentials.
api.access_key_id = ""
api.secret_access_key = ""
# Optional temporary-session credential token.
api.session_token = ""
# Optional endpoint override (for testing/emulation).
api.endpoint_url = ""
default_from = "noreply@example.com"
configuration_set_name = ""

# === Groq ===
[groq]
# Operation defaults for Groq chat completions.
# top_p defaults to 1.0 when omitted; kept explicit here for readability.
api.classification.model = ""
api.classification.temp = 0.0
api.classification.top_p = 1.0
api.completion.model = ""
api.completion.temp = 0.0
api.completion.top_p = 1.0
api.timeout_seconds = 30.0
api.key = "<groq-api-key>"

# === OpenAI ===
[openai]
# Operation defaults for OpenAI gateway.
# surface selects OpenAI API surface per operation:
# - "chat_completions" (default)
# - "responses"
# Per-request override remains available through
# CompletionRequest.vendor_params["openai_api"].
# max_completion_tokens is preferred. max_tokens remains as compatibility alias.
# stream behavior and provider-specific extras can be overridden per request
# through CompletionRequest vendor_params.
api.classification.model = ""
api.classification.surface = "chat_completions"
api.classification.temp = 0.0
api.classification.top_p = 1.0
api.classification.max_completion_tokens = 1024
api.classification.max_tokens = 1024
api.completion.model = ""
api.completion.surface = "chat_completions"
api.completion.temp = 0.0
api.completion.top_p = 1.0
api.completion.max_completion_tokens = 1024
api.completion.max_tokens = 1024
api.base_url = ""
api.timeout_seconds = 30.0
api.key = "<openai-api-key>"

# === Matrix ===
[matrix]
assistant.name = ""
beta.users = []
client.device = "mugen"
client.password = "<matrix-password>"
client.user = ""
domain = ""
domains.allowed = []
domains.denied = []
homeserver = ""
invites.direct_only = true
media.allowed_mimetypes = [
  "audio/*",
  "image/*",
  "video/*",
  "application/*",
  "text/*",
]
media.max_download_bytes = 20_971_520   # 20 MiB
ipc.queue_size = 256
ipc.enqueue_timeout_seconds = 2.0
security.device_trust.mode = "strict_known"
# Optional allowlist entries used when security.device_trust.mode = "allowlist".
# [[matrix.security.device_trust.allowlist]]
# user_id = "@user:example.com"
# device_ids = ["DEVICEID1", "DEVICEID2"]
storage.olm.path = "/absolute/path/to/data/.olmstore"

[security.secrets]
# Required in production when Matrix platform is enabled.
encryption_key = "<set-secret-encryption-key>"

# === Qdrant ===
[qdrant]
api.key = "<qdrant-api-key>"
api.url = ""
api.timeout_seconds = 10.0
api.max_retries = 2
api.retry_backoff_seconds = 0.5
encoder.preload = false
encoder.max_concurrency = 4

# === Quart ===
[quart]
secret_key = "<set-quart-secret-key>"

# === RDBMS ===
[rdbms.alembic]
# Alembic requires a synchronous driver.
url = "postgresql+psycopg://user:password@server/database"

[rdbms.sqlalchemy]
# SQLAlchemy requires an asynchronous driver.
url = "postgresql+psycopg://user:password@server/database"

[rdbms.migration_tracks.core]
# Core track remains the default migration lineage.
enabled = true
alembic_config = "alembic.ini"
schema = "mugen"
version_table = "alembic_version"
version_table_schema = "mugen"

# Downstream plugin tracks run independently from core.
# Each track gets its own schema + version table contract.
# [[rdbms.migration_tracks.plugins]]
# name = "acme_extension"
# enabled = true
# alembic_config = "plugins/acme_extension/alembic.ini"
# schema = "acme_extension"
# version_table = "alembic_version"
# version_table_schema = "acme_extension"
# model_modules = ["acme_extension.model.base"]

# === SambaNova ===
[sambanova]
# Operation defaults for SambaNova chat completions.
# auth_scheme: bearer (default) or basic (legacy environments).
# token_limit_field: max_tokens (default) or max_completion_tokens.
# max_completion_tokens/max_tokens: fallback token limits when request
# inference does not set them; keep both values aligned for compatibility.
# stop: default stop sequences used only when request inference.stop is unset.
# Repeat these operation knobs for both classification and completion.
api.classification.model = ""
api.classification.auth_scheme = "bearer"
api.classification.token_limit_field = "max_tokens"
api.classification.max_completion_tokens = 1024
api.classification.max_tokens = 1024
api.classification.temp = 0.0
api.classification.stop = []
api.completion.model = ""
api.completion.auth_scheme = "bearer"
api.completion.token_limit_field = "max_tokens"
api.completion.max_completion_tokens = 1024
api.completion.max_tokens = 1024
api.completion.temp = 0.0
api.completion.stop = []
api.endpoint = ""
api.connect_timeout_seconds = 10.0
api.read_timeout_seconds = 30.0
api.key = "<sambanova-api-key>"

# === SMTP (optional outbound email gateway) ===
[smtp]
host = "smtp.example.com"
port = 587
username = ""
password = ""
default_from = "noreply@example.com"
timeout_seconds = 30.0
use_ssl = false
starttls = true
starttls_required = true

# === Telnet (dev/test harness only) ===
[telnet]
socket.host = "localhost"
socket.port = 8888
# Maximum seconds to wait for input before disconnecting (<=0 disables timeout).
read_timeout_seconds = 300.0
# Maximum raw input bytes accepted for one prompt.
max_prompt_bytes = 4096

# === Transformers ===
[transformers]
hf.home = "/absolute/path/to/hf/cache"

# === WhatsApp ===
[whatsapp]
app.id = "<whatsapp-app-id>"
app.secret = "<whatsapp-app-secret>"
beta.users = []
business.phone_number_id = ""
graphapi.access_token = "<whatsapp-graph-access-token>"
graphapi.base_url = "https://graph.facebook.com"
graphapi.version = "v20.0"
# Graph API request timeout in seconds.
graphapi.timeout_seconds = 10.0
# Maximum bytes allowed when downloading media from Graph API.
graphapi.max_download_bytes = 20971520
# Enables best-effort typing indicators for processing messages.
graphapi.typing_indicator_enabled = true
servers.allowed = ""
servers.verify_ip = false
# Trust `X-Forwarded-For` only when running behind trusted reverse proxies.
servers.trust_forwarded_for = false
webhook.verification_token = "<whatsapp-webhook-verification-token>"
# Dedupe retention window for webhook event keys.
webhook.dedupe_ttl_seconds = 86400

# === Web ===
[web]
sse.keepalive_seconds = 15
sse.replay_max_events = 200
queue.poll_interval_seconds = 0.25
queue.processing_lease_seconds = 30
queue.max_pending_jobs = 2000
media.backend = "filesystem"
media.storage.path = "/absolute/path/to/data/web_media"
media.max_upload_bytes = 20971520
# Max attachments per structured message payload.
media.max_attachments_per_message = 10
media.allowed_mimetypes = [
  "audio/*",
  "video/*",
  "image/*",
  "application/*",
]
media.download_token_ttl_seconds = 900
media.retention_seconds = 86400
media.object.cache_path = "/absolute/path/to/data/web_media_object_cache"
media.object.key_prefix = "web:media:object"
