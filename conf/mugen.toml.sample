[mugen]
# Assistant persona is ACP-managed through context_engine ContextProfiles.Persona.
debug_conversation = false
environment = "development"
platforms = [
  "web",
  # "line",
  # "matrix",
  # "signal",
  # "telegram",
  # "wechat",
  # "whatsapp",
]

[mugen.commands]
clear = "..."

[mugen.logger]
level = 10
name = "COM.VORSOCOMPUTING.MUGEN"

[mugen.messaging]
# Controls message-handler requirements:
# - optional: zero-MH runtime is supported with core built-in text orchestration.
# - required: startup fails if no MH extension is available for active messaging platforms.
mh_mode = "optional"
# Max number of chat history messages persisted and forwarded to completion context.
history_max_messages = 40
# Max CAS retries for chat-history persistence across workers/processes.
history_save_cas_retries = 5
# Timeout in seconds for extension callbacks (CP/MH/RPP/CT).
extension_timeout_seconds = 10.0
# If true, CT extensions with non-empty triggers only run on trigger matches.
ct_trigger_prefilter_enabled = true

[mugen.runtime]
# Required runtime bootstrap mode. Currently only `platform_full` is accepted;
# `auto`, blank, and legacy profile names are rejected.
profile = "platform_full"
provider_readiness_timeout_seconds = 15.0
# Required deterministic shutdown timeouts (must be > 0).
provider_shutdown_timeout_seconds = 10.0
shutdown_timeout_seconds = 60.0

[mugen.runtime.phase_b]
readiness_grace_seconds = 0.0
startup_timeout_seconds = 30.0
critical_platforms = ["web"]
degrade_on_critical_exit = true

[mugen.storage.keyval.relational]
namespace_default = "core"
list_limit_default = 200

[mugen.modules.core.client]
# Provider values are strict tokens (for example `bedrock`, `cerebras`,
# `openai`, `azure_foundry`, `vertex`, `smtp`),
# not Python module paths.
line = "default"
matrix = "default"
signal = "default"
telegram = "default"
wechat = "default"
web = "default"
whatsapp = "default"

[mugen.modules.core.gateway]
# Completion gateway.
# Available tokens:
completion = "deterministic"
# completion = "azure_foundry"
# completion = "bedrock"
# completion = "cerebras"
# completion = "sambanova"
# completion = "groq"
# completion = "openai"
# completion = "vertex"

# Email gateway (optional).
# Available tokens:
# email = "smtp"
# email = "ses"

# Knowledge gateway (optional).
# Available tokens:
# knowledge = "chromadb"
# knowledge = "milvus"
# knowledge = "pinecone"
# knowledge = "pgvector"
# knowledge = "qdrant"
# knowledge = "weaviate"

# Logging gateway.
# Available tokens:
logging = "standard"

# SMS gateway (optional).
# Available tokens:
# sms = "twilio"

[mugen.modules.core.gateway.storage]
keyval = "relational"
media = "default"
relational = "sqlalchemy"
web_runtime = "relational"

[mugen.modules.core.service]
ipc = "default"
ingress = "default"
context_engine = "default"
messaging = "default"
nlp = "default"
platform = "default"
user = "default"

# Unified extensions.
[[mugen.modules.extensions]]
type = "cp"
token = "core.cp.clear_history"

# Framework entries may optionally declare:
# enabled = true
# name = "com.vorsocomputing.mugen.plugin_name"
# namespace = "com.vorsocomputing.mugen.plugin_name"
# contrib = "mugen.core.plugin.plugin_name.contrib"
# Model-bearing FW plugins should also declare:
# models = "mugen.core.plugin.plugin_name.model"
# migration_track = "core"
#
# Web platform FW contract (required when `web` is active).
[[mugen.modules.extensions]]
type = "fw"
token = "core.fw.acp"
enabled = true
name = "com.vorsocomputing.mugen.acp"
namespace = "com.vorsocomputing.mugen.acp"
models = "mugen.core.plugin.acp.model"
migration_track = "core"
contrib = "mugen.core.plugin.acp.contrib"

[[mugen.modules.extensions]]
type = "fw"
token = "core.fw.web"
enabled = true
name = "com.vorsocomputing.mugen.web"
namespace = "com.vorsocomputing.mugen.web"
models = "mugen.core.plugin.web.model"
migration_track = "core"
contrib = "mugen.core.plugin.web.contrib"

[[mugen.modules.extensions]]
type = "fw"
token = "core.fw.context_engine"
enabled = true
name = "com.vorsocomputing.mugen.context_engine"
namespace = "com.vorsocomputing.mugen.context_engine"
contrib = "mugen.core.plugin.context_engine.contrib"

