[mugen]
assistant.persona = ""
beta.active = true
beta.message = ""
debug_conversation = false
environment = "development"
logger.level = 10
logger.name = "COM.VORSOCOMPUTING.MUGEN"
platforms = [
  "telnet",
  # "web",
  # "matrix",
  # "whatsapp",
]
storage.keyval.dbm.path = "/absolute/path/to/data/storage.db"

[mugen.commands]
clear = "..."

[mugen.messaging]
# Max number of chat history messages persisted and forwarded to completion context.
history_max_messages = 40
# Timeout in seconds for extension callbacks (CP/CTX/RAG/RPP/CT).
extension_timeout_seconds = 10.0
# If true, CT extensions with non-empty triggers only run on trigger matches.
ct_trigger_prefilter_enabled = true

[mugen.modules.core]
client.telnet = "mugen.core.client.telnet"
client.matrix = "mugen.core.client.matrix"
client.whatsapp = "mugen.core.client.whatsapp"
client.web = "mugen.core.client.web"

gateway.completion = "mugen.core.gateway.completion.bedrock"
# gateway.email = "mugen.core.gateway.email.smtp"
# gateway.email = "mugen.core.gateway.email.ses"
# gateway.knowledge = "mugen.core.gateway.knowledge.qdrant"
gateway.logging = "mugen.core.gateway.logging.standard"
gateway.storage.keyval = "mugen.core.gateway.storage.keyval.dbm"
gateway.storage.relational = "mugen.core.gateway.storage.rdbms.sqla.sqla_gateway"

service.ipc = "mugen.core.service.ipc"
service.messaging = "mugen.core.service.messaging"
service.nlp = "mugen.core.service.nlp"
service.platform = "mugen.core.service.platform"
service.user = "mugen.core.service.user"

# Core framework plugins.
[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.acp.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.acp"
namespace = "com.vorsocomputing.mugen.acp"
models = "mugen.core.plugin.acp.model"
contrib = "mugen.core.plugin.acp.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.audit.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.audit"
namespace = "com.vorsocomputing.mugen.audit"
models = "mugen.core.plugin.audit.model"
contrib = "mugen.core.plugin.audit.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_vpn.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_vpn"
namespace = "com.vorsocomputing.mugen.ops_vpn"
models = "mugen.core.plugin.ops_vpn.model"
contrib = "mugen.core.plugin.ops_vpn.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_case.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_case"
namespace = "com.vorsocomputing.mugen.ops_case"
models = "mugen.core.plugin.ops_case.model"
contrib = "mugen.core.plugin.ops_case.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_sla.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_sla"
namespace = "com.vorsocomputing.mugen.ops_sla"
models = "mugen.core.plugin.ops_sla.model"
contrib = "mugen.core.plugin.ops_sla.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_metering.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_metering"
namespace = "com.vorsocomputing.mugen.ops_metering"
models = "mugen.core.plugin.ops_metering.model"
contrib = "mugen.core.plugin.ops_metering.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_workflow.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_workflow"
namespace = "com.vorsocomputing.mugen.ops_workflow"
models = "mugen.core.plugin.ops_workflow.model"
contrib = "mugen.core.plugin.ops_workflow.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_governance.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_governance"
namespace = "com.vorsocomputing.mugen.ops_governance"
models = "mugen.core.plugin.ops_governance.model"
contrib = "mugen.core.plugin.ops_governance.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.ops_reporting.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.ops_reporting"
namespace = "com.vorsocomputing.mugen.ops_reporting"
models = "mugen.core.plugin.ops_reporting.model"
contrib = "mugen.core.plugin.ops_reporting.contrib"

[[mugen.modules.core.plugins]]
type = "fw"
path = "mugen.core.plugin.billing.fw_ext"
enabled = true
name = "com.vorsocomputing.mugen.billing"
namespace = "com.vorsocomputing.mugen.billing"
